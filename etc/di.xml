<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <preference for="Buhmann\StockStatus\Api\ItemFactoryProviderInterface" type="Buhmann\StockStatusSmile\Model\Provider\ItemFactoryProvider"/>

    <virtualType name="StockStatusSmileItemFactory" type="Magento\Catalog\Model\Layer\Filter\ItemFactory">
        <arguments>
            <argument name="instanceName" xsi:type="string">Buhmann\StockStatusSmile\Model\Layer\Filter\Item\Stock</argument>
        </arguments>
    </virtualType>

    <type name="Buhmann\StockStatusSmile\Model\Provider\ItemFactoryProvider">
        <arguments>
            <argument name="itemFactory" xsi:type="object">StockStatusSmileItemFactory</argument>
        </arguments>
    </type>

    <type name="Smile\ElasticsuiteCatalog\Model\Product\Indexer\Fulltext\Datasource\AttributeData">
        <plugin name="buhmann_stock_smile_add_stock_status" type="Buhmann\StockStatusSmile\Plugin\AddStockStatusToIndex" sortOrder="10"/>
    </type>

    <type name="Smile\ElasticsuiteCore\Search\Request\ContainerConfiguration">
        <plugin name="buhmann_stock_smile_add_aggregation" type="Buhmann\StockStatusSmile\Plugin\AddStockStatusAggregation" sortOrder="10"/>
    </type>

    <type name="Smile\ElasticsuiteCore\Api\Index\MappingInterface">
        <plugin name="buhmann_stock_smile_fix_mapping" type="Buhmann\StockStatusSmile\Plugin\MappingCache" sortOrder="10"/>
    </type>
</config>
